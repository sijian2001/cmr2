<%= form_with(model: store, local: true) do |form| %>
  <% if store.errors.any? %>
    <div class="error-messages">
      <h4><%= pluralize(store.errors.count, "個のエラー") %>があります:</h4>
      <ul>
        <% store.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= form.label :name, "店舗名" %>
    <%= form.text_field :name, required: true %>
  </div>

  <div class="form-group">
    <%= form.label :manager_name, "店長名" %>
    <%= form.text_field :manager_name, required: true %>
  </div>

  <div class="form-group">
    <%= form.label :address, "住所" %>
    <%= form.text_area :address, rows: 3, required: true %>
  </div>

  <div class="form-group">
    <%= form.label :phone, "電話番号" %>
    <%= form.telephone_field :phone, required: true %>
  </div>

  <div class="form-group">
    <%= form.label :email, "メールアドレス" %>
    <%= form.email_field :email %>
  </div>

  <div class="form-group">
    <%= form.label :opening_hours, "営業時間" %>
    <%= form.text_field :opening_hours, placeholder: "例: 9:00-21:00" %>
  </div>

  <div class="form-group">
    <%= form.label :description, "説明" %>
    <%= form.text_area :description, rows: 4 %>
  </div>

  <div class="form-group checkbox-group">
    <%= form.check_box :is_active %>
    <%= form.label :is_active, "営業中" %>
  </div>

  <div class="form-actions">
    <%= form.submit store.persisted? ? "更新" : "登録", class: "btn btn-primary" %>
    <%= link_to "キャンセル", store.persisted? ? store : stores_path, class: "btn btn-cancel" %>
  </div>
<% end %>