<div class="store-show">
  <div class="header">
    <h1><%= @store.name %></h1>
    <div class="status-badge status-<%= @store.is_active? ? 'active' : 'inactive' %>">
      <%= @store.status_text %>
    </div>
  </div>

  <div class="actions">
    <%= link_to "編集", edit_store_path(@store), class: "btn btn-primary" %>
    <%= link_to "削除", @store, method: :delete,
        data: { confirm: "本当に削除しますか？" },
        class: "btn btn-delete" %>
    <%= link_to "店舗一覧に戻る", stores_path, class: "btn btn-secondary" %>
  </div>

  <div class="store-details">
    <div class="detail-section">
      <h3>基本情報</h3>
      <div class="detail-row">
        <label>店舗名:</label>
        <span><%= @store.name %></span>
      </div>
      <div class="detail-row">
        <label>店長:</label>
        <span><%= @store.manager_name %></span>
      </div>
      <div class="detail-row">
        <label>住所:</label>
        <span><%= @store.address %></span>
      </div>
      <div class="detail-row">
        <label>営業時間:</label>
        <span><%= @store.opening_hours.present? ? @store.opening_hours : "未設定" %></span>
      </div>
      <div class="detail-row">
        <label>営業状態:</label>
        <span class="status-<%= @store.is_active? ? 'active' : 'inactive' %>">
          <%= @store.status_text %>
        </span>
      </div>
    </div>

    <div class="detail-section">
      <h3>連絡先</h3>
      <div class="detail-row">
        <label>電話番号:</label>
        <span><%= @store.phone %></span>
      </div>
      <% if @store.email.present? %>
        <div class="detail-row">
          <label>メールアドレス:</label>
          <span><%= mail_to @store.email, @store.email %></span>
        </div>
      <% end %>
      <div class="detail-row">
        <label>連絡先情報:</label>
        <span><%= @store.contact_info %></span>
      </div>
    </div>

    <% if @store.description.present? %>
      <div class="detail-section">
        <h3>説明</h3>
        <div class="description">
          <%= simple_format(@store.description) %>
        </div>
      </div>
    <% end %>

    <div class="detail-section">
      <h3>完全情報</h3>
      <div class="full-info">
        <%= @store.full_info %>
      </div>
    </div>
  </div>

  <div class="timestamps">
    <p><strong>作成日時:</strong> <%= @store.created_at.strftime("%Y年%m月%d日 %H:%M") %></p>
    <p><strong>更新日時:</strong> <%= @store.updated_at.strftime("%Y年%m月%d日 %H:%M") %></p>
  </div>
</div>
