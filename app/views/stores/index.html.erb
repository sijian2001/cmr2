<div class="stores-index">
  <h1>店舗管理</h1>

  <div class="actions">
    <%= link_to "新規店舗登録", new_store_path, class: "btn btn-primary" %>
    <%= link_to "ホームに戻る", root_path, class: "btn btn-secondary" %>
  </div>

  <div class="search-form">
    <%= form_with url: stores_path, method: :get, local: true do |form| %>
      <div class="search-fields">
        <%= form.text_field :search_name, placeholder: "店舗名で検索", value: params[:search_name] %>
        <%= form.text_field :search_address, placeholder: "住所で検索", value: params[:search_address] %>
        <%= form.text_field :search_manager, placeholder: "店長名で検索", value: params[:search_manager] %>

        <%= form.select :status_filter,
            options_for_select([
              ["営業状態", ""],
              ["営業中", "active"],
              ["営業停止", "inactive"]
            ], params[:status_filter]),
            {}, { class: "select-filter" } %>

        <%= form.submit "検索", class: "btn btn-search" %>
        <%= link_to "クリア", stores_path, class: "btn btn-clear" %>
      </div>
    <% end %>
  </div>

  <div class="stores-table">
    <% if @stores.any? %>
      <table>
        <thead>
          <tr>
            <th>店舗名</th>
            <th>店長</th>
            <th>住所</th>
            <th>電話番号</th>
            <th>営業時間</th>
            <th>営業状態</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody>
          <% @stores.each do |store| %>
            <tr>
              <td><%= link_to store.name, store, class: "store-link" %></td>
              <td><%= store.manager_name %></td>
              <td><%= truncate(store.address, length: 30) %></td>
              <td><%= store.phone %></td>
              <td><%= store.opening_hours %></td>
              <td class="status-<%= store.is_active? ? 'active' : 'inactive' %>">
                <%= store.status_text %>
              </td>
              <td class="actions">
                <%= link_to "表示", store, class: "btn btn-show" %>
                <%= link_to "編集", edit_store_path(store), class: "btn btn-edit" %>
                <%= link_to "削除", store, method: :delete,
                    data: { confirm: "本当に削除しますか？" },
                    class: "btn btn-delete" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="no-stores">店舗が見つかりませんでした。</p>
    <% end %>
  </div>

  <div class="summary">
    <p>合計: <%= @stores.count %>件</p>
    <% if @stores.any? %>
      <p>
        営業中: <%= @stores.active.count %>件 |
        営業停止: <%= @stores.inactive.count %>件
      </p>
    <% end %>
  </div>
</div>
