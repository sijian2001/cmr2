<div class="staff-show">
  <div class="header">
    <h1><%= @staff.name %></h1>
    <div class="status-badge status-<%= @staff.is_active? ? 'active' : 'inactive' %>">
      <%= @staff.status_text %>
    </div>
  </div>

  <div class="actions">
    <%= link_to "編集", edit_staff_path(@staff), class: "btn btn-primary" %>
    <%= link_to "削除", @staff, method: :delete,
        data: { confirm: "本当に削除しますか？" },
        class: "btn btn-delete" %>
    <%= link_to "店員一覧に戻る", staffs_path, class: "btn btn-secondary" %>
  </div>

  <div class="staff-details">
    <div class="detail-section">
      <h3>基本情報</h3>
      <div class="detail-row">
        <label>氏名:</label>
        <span><%= @staff.name %></span>
      </div>
      <div class="detail-row">
        <label>社員ID:</label>
        <span><%= @staff.employee_id %></span>
      </div>
      <div class="detail-row">
        <label>職位:</label>
        <span><%= @staff.position %></span>
      </div>
      <% if @staff.department.present? %>
        <div class="detail-row">
          <label>部署:</label>
          <span><%= @staff.department %></span>
        </div>
      <% end %>
      <div class="detail-row">
        <label>所属店舗:</label>
        <span><%= link_to @staff.store.name, @staff.store if @staff.store %></span>
      </div>
      <div class="detail-row">
        <label>在籍状況:</label>
        <span class="status-<%= @staff.is_active? ? 'active' : 'inactive' %>">
          <%= @staff.status_text %>
        </span>
      </div>
    </div>

    <div class="detail-section">
      <h3>連絡先</h3>
      <% if @staff.phone.present? %>
        <div class="detail-row">
          <label>電話番号:</label>
          <span><%= @staff.phone %></span>
        </div>
      <% end %>
      <% if @staff.email.present? %>
        <div class="detail-row">
          <label>メールアドレス:</label>
          <span><%= mail_to @staff.email, @staff.email %></span>
        </div>
      <% end %>
      <% if @staff.contact_info.present? %>
        <div class="detail-row">
          <label>連絡先情報:</label>
          <span><%= @staff.contact_info %></span>
        </div>
      <% end %>
    </div>

    <div class="detail-section">
      <h3>雇用情報</h3>
      <div class="detail-row">
        <label>入社日:</label>
        <span><%= @staff.hire_date.strftime("%Y年%m月%d日") if @staff.hire_date %></span>
      </div>
      <div class="detail-row">
        <label>勤続年数:</label>
        <span><%= @staff.years_of_service %>年</span>
      </div>
      <div class="detail-row">
        <label>給与:</label>
        <span><%= @staff.formatted_salary %></span>
      </div>
    </div>

    <div class="detail-section">
      <h3>完全情報</h3>
      <div class="full-info">
        <%= @staff.full_info %>
      </div>
    </div>
  </div>

  <div class="timestamps">
    <p><strong>作成日時:</strong> <%= @staff.created_at.strftime("%Y年%m月%d日 %H:%M") %></p>
    <p><strong>更新日時:</strong> <%= @staff.updated_at.strftime("%Y年%m月%d日 %H:%M") %></p>
  </div>
</div>
